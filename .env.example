# ============================================================
# Copiază acest fișier ca ".env" pentru testare LOCALĂ.
# NU adăuga niciodată fișierul ".env" în git (e deja în .gitignore).
# Pe GitHub, aceste valori se setează ca "Secrets" (vezi Pasul 4 din README).
# ============================================================

# --- Supabase (Settings -> API în dashboard-ul proiectului tău) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini (https://aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram Bot (creat cu @BotFather) ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=123456789

# --- YouTube Data API v3 (Google Cloud Console, OAuth) ---
YOUTUBE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Pexels (https://www.pexels.com/api/) - optional, pentru stock footage ---
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Pixabay (https://pixabay.com/api/docs/) - optional, a doua sursa de stock footage ---
PIXABAY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
